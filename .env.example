EPS_DATA_DIR=/path/to/eps/export
BACI_DIR=/path/to/baci

# Atlas IIDS (OpenXLab) — set on cloud VM only; never commit .env
OPENXLAB_AK=your_rotated_access_key
OPENXLAB_SK=your_rotated_secret_key
OPENXLAB_IIDS_SOURCES_DIR=/mnt/iids_sources
OPENXLAB_INSECURE_SSL=1
ATLAS_EXPORT_OWNER=your_name_or_team
